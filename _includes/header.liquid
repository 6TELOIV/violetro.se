<style>
    .skip-link {
        position: fixed;
        top: 0.5rem;
        left: 50%;
        transform: translateX(-50%);
        border-radius: 0.5rem;
        padding: 0.5rem 1rem;
        background: white;
        color: black;
        text-decoration: none;
    }

    header {
        border-bottom: 1px solid;
    }

    .navbar {
        max-width: var(--xl);
        padding-inline: 0.5rem;
        margin-inline: auto;
        display: flex;
        justify-content: space-between;
        align-items: stretch;
    }

    .navbar--logo {
        color: currentColor;
        text-decoration: none;
        padding: 0 0.5rem;
        gap: 0.5rem;
        display: flex;
        align-items: center;
        font-size: 1.25em;
        line-height: 1;
    }

    .navbar--logo img,
    .navbar--logo svg {
        height: 2em;
        width: 2em;
    }
    
    .nav-open,
    .nav-close {
        border: none;
        border-radius: 0;
        background: transparent;
        padding: 0.5rem 0.25rem;
    }
    .nav-open {
        margin: 0.5rem 0.25rem;
    }

    .nav-open svg,
    .nav-close svg {
        height: 1.5rem;
        width: 1.5rem;
    }

    .nav {
        display: none;
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .nav--item {
        padding: 0.5rem 0.25rem;
        font-weight: 450;
    }
    .nav--item a {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.5rem 0.5rem;
        text-decoration: none;
        color: currentColor;
        border-radius: 0.5rem;
    }
    .nav--item--active a {
        background-color: SelectedItem;
        color: SelectedItemText;
    }

    #dialog-menu:open {
        display: flex;
        flex-direction: column;
        margin: 0;
        max-width: 75%;
        width: 16rem;
        max-height: none;
        height: 100%;
        margin-inline-start: auto;
        border: none;
        border-inline-start: 1px solid black;
        background-color: white;
        gap: 0.5rem;
    }
    #dialog-menu::backdrop {
        background-color: rgba(0, 0, 0, 0.5);
        pointer-events: none;
    }
    #dialog-menu .nav {
        display: grid;
        gap: 0.5rem;
    }
    #dialog-menu .nav .nav--item{
        padding: 0;
    }

    .dialog-menu--header {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .dialog-menu--header h2 {
        margin: 0;
    }

    @media screen and (min-width: 576px) {
        .nav {
            display: flex;
        }
        .nav-open {
            display: none;
        }
    }
</style>
<a href="#main" class="visually-hidden-focusable skip-link">Skip to main content</a>
<header>
    <nav class="navbar">
        <a href="/" class="navbar--logo">{{ metadata.title }}</a>
        {% include 'nav' %}
        <button command="show-modal" commandfor="dialog-menu" class="nav-open" type="button" aria-label="Open Menu"><i class="fa-solid fa-bars"></i></button>
        <dialog aria-labelledby="dialog-menu--title" id="dialog-menu" data-backdrop-dismisses>
            <div class="dialog-menu--header">
                <h2 id="dialog-menu--title">Menu</h2>
                <button class="nav-close" command="close" commandfor="dialog-menu" aria-label="Close Menu"><i class="fa-solid fa-close"></i></button>
            </div>
            {% include 'nav' %}
        </dialog>
    </nav>
</header>
